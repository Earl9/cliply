{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cliply",
  "version": "0.4.1-beta.7",
  "identifier": "com.cliply.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cliply",
        "label": "main",
        "width": 1040,
        "height": 680,
        "minWidth": 860,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/blobs/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": {
        "template": "wix/main.wxs",
        "language": {
          "zh-CN": {
            "localePath": "wix/zh-CN.wxl"
          }
        },
        "bannerPath": "wix/banner.bmp",
        "dialogImagePath": "wix/dialog.bmp"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"],
        "customLanguageFiles": {
          "SimpChinese": "nsis/SimpChinese.nsh",
          "English": "nsis/English.nsh"
        },
        "installerHooks": "nsis/installer-hooks.nsh",
        "displayLanguageSelector": false,
        "startMenuFolder": "Cliply"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMyRjRCNzgzOTgzMTUzRgpSV1EvRllNNWVFc3ZBMUFwbHBGSEpNKzNvWndEdHJ3UXJ0YzVER3NWZ2cxVk53dmtjUnNWS2tFUAo=",
      "endpoints": [
        "https://github.com/Earl9/cliply/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive",
        "installerArgs": []
      }
    }
  }
}
